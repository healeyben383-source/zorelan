# Zorelan — environment variables.
#
# Copy to .env.local for local dev. For production, set the same vars in
# Vercel → Project Settings → Environment Variables. NEXT_PUBLIC_* vars are
# inlined at build time, so the production build needs them set before the
# build runs.
#
# This file is PLACEHOLDERS ONLY. Never commit real values. .env*.local is
# gitignored. Do not invent values — fill these in from the real provider
# dashboards when configuring an environment.

# ─── AI providers (the decision layer queries these) ──────────────
# At least the providers you intend to use must be set, or their calls fail.
ANTHROPIC_API_KEY=replace-with-anthropic-key
OPENAI_API_KEY=replace-with-openai-key
GEMINI_API_KEY=replace-with-google-gemini-key
PERPLEXITY_API_KEY=replace-with-perplexity-key

# Optional model overrides (fall back to in-code defaults if unset).
# OPENAI_MODEL=
# OPENAI_SEMANTIC_JUDGE_MODEL=
# ANTHROPIC_SEMANTIC_JUDGE_MODEL=

# ─── API authentication ───────────────────────────────────────────
# DECISION_API_KEY gates the server-side decision/verify endpoints.
# ZORELAN_API_KEY is the client/SDK key used by examples and the docs page.
DECISION_API_KEY=replace-with-server-decision-api-key
ZORELAN_API_KEY=replace-with-public-sdk-api-key

# Enable in-app rate limiting (requires Upstash Redis below).
# ENABLE_API_RATE_LIMIT=true

# ─── Upstash Redis (rate limiting, usage, provider scores) ─────────
KV_REST_API_URL=https://your-instance.upstash.io
KV_REST_API_TOKEN=replace-with-upstash-token

# ─── Stripe (checkout + webhook billing) ──────────────────────────
# Without these, checkout and webhook handling are disabled.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_STARTER=price_replace_me
STRIPE_PRICE_PRO=price_replace_me
STRIPE_PRICE_SCALE=price_replace_me

# ─── Resend (transactional email) ─────────────────────────────────
RESEND_API_KEY=re_replace_me

# ─── Owner / support contact ──────────────────────────────────────
# OWNER_NOTIFICATION_EMAIL: if set, Zorelan emails the owner on each new paid
# signup (customer email, plan, IDs, API-key prefix only). Optional — checkout
# never fails if this send fails or is unset.
# OWNER_NOTIFICATION_EMAIL=owner@yourdomain.com
# SUPPORT_EMAIL: shown as the public support/contact address. Falls back to
# support@zorelan.com in the UI if unset.
# SUPPORT_EMAIL=support@yourdomain.com

# ─── Cron (scheduled usage reset) ─────────────────────────────────
# Shared secret the cron route checks before running.
CRON_SECRET=replace-with-cron-secret

# ─── App URLs ─────────────────────────────────────────────────────
# Public base URL of the deployment (used for redirects + self-calls).
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Optional override for the demo's self-call base URL.
# ZORELAN_BASE_URL=
